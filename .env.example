# openCMP Environment Configuration
# Copy this file to .env and modify values for production deployment

# ===========================================
# Database Configuration
# ===========================================
MYSQL_ROOT_PASSWORD=opencmp123
MYSQL_PASSWORD=opencmp123
MYSQL_PORT=3306
DB_HOST=mysql
DB_PORT=3306
DB_USER=opencmp
DB_PASSWORD=opencmp123
DB_NAME=opencmp

# ===========================================
# Redis Configuration
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# Server Configuration
# ===========================================
SERVER_PORT=8080
SERVER_MODE=release
BACKEND_PORT=8080
FRONTEND_PORT=80

# ===========================================
# Security Configuration
# ===========================================
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRATION=24

# ===========================================
# Logging Configuration
# ===========================================
LOG_LEVEL=info

# ===========================================
# Frontend Configuration
# ===========================================
VITE_API_BASE_URL=/api/v1
NGINX_HTTP_PORT=8081
NGINX_HTTPS_PORT=443